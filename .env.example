# Google Gemini API key — requis pour /mentionable-images
# Obtenir une clé : https://aistudio.google.com/apikey
# La génération d'images (gemini-2.5-flash-image) nécessite un projet avec billing activé.
GEMINI_API_KEY=

# DataForSEO — requis pour /mentionable-pillar
# Créer un compte : https://app.dataforseo.com (crédits offerts à l'inscription).
# Voir docs/dataforseo-setup.md pour le walkthrough.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Localisation par défaut pour DataForSEO (optionnel, override par CLI : --location / --language).
# Codes : https://docs.dataforseo.com/v3/serp/google/locations/
# 2250 = France · 2840 = US · 2826 = UK · 2724 = Spain · 2276 = Germany
LOCATION_CODE=2250
LANGUAGE_CODE=fr
